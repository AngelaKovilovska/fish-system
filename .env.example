# ── Датабаза ──
DATABASE_URL=postgresql://user:password@localhost:5432/clario

# ── Сервер ──
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── JWT ──
# Мин. 32 карактери — генерирај со: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-characters-long

# ── Админ (автоматски се креира ако нема корисници) ──
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!
ADMIN_NAME=Администратор

# ── Email известувања (Brevo HTTP API) ──
# Регистрирај се на https://brevo.com → Settings → SMTP & API → API Keys
BREVO_API_KEY=your-brevo-api-key
# Email адреса верификувана на Brevo (Settings → Senders)
EMAIL_FROM=famakom@t.mk
